                   }
    },

	"network": {
        "on-click": "networkmanager_dmenu",
   		"format-wifi": "σΑ•©",
   		"format-ethernet": "σΑàÄ",
   		"format-disconnected": "σΑΣé",
   		"interval": 5,
        "tooltip-format-wifi":"{essid} {bandwidthDownBits}",
        "tooltip-format-ethernet":"{bandwidthDownBits}",
        "tooltip-format-disconnected": "Check internet connection",
 	 }
}
