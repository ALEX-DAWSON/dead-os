{
	"layer": "bot",
	"spacing": 0,
	"height": 0,
	"margin-top": 0,
	"position": "top",
	"margin-right": 0,
	"margin-left": 0,
	"refresh-on-change": true,


	"modules-left": [
		"custom/launcher",
		"hyprland/workspaces",
        "custom/now-playing",
	],

	"modules-center": [
		"clock"
	],

	"modules-right": [
		"network",
		"pulseaudio",
		"tray",
        "battery",
        "custom/power"
	],

    "clock": {
        "tooltip": true,
        "tooltip-format": "{:%B %d %Y}"
    },

	"hyprland/workspaces": {
		"tooltip": false
	},

	"tray": {
  		 "spacing": 10,
  		 "tooltip": false
  	},

	"custom/launcher": {
    		"format": "σΑΘ΅",
    		"on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
    		"tooltip-format": "Menu"
 	},

    "battery": {
        "bat": "BAT0",
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"], 
        "states": {
            "warning": 30,
            "critical": 15
        },
    },

	"custom/power": {
        "format": "σΑêΞ",
        "on-click": "power.sh",
        "tooltip-format": "Power"
 	},

    "custom/now-playing": {
        "hide-empty-text": true,
        "format": "{}",
        "exec": "~/.config/scripts/now-playing.sh",
        "exec-if": "pgrep spotify"
    },

    "pulseaudio" : {
        "on-click": "audioctl",
        "format": "{icon} {volume}%",
        "format-muted": "σΑùü",
        "format-icons": { 
            "headphone": "σΑ΄΄",
            "headphone-muted": "σΑüé",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
        },
    },

    "cava": {
        "framerate": 30,
        "autosense": 1,
        "sensitivity": 100,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "hide_on_silence": false,
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons": ["β•¹", "β•²", "β•É", "β•³", "β•Ö", "β•Ü", "β•΅", "β•à" ],
        "actions": {
