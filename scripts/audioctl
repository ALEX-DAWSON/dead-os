#!/usr/bin/env bash

# -----Colors--------------------------------------------
. ~/.cache/wal/colors.sh

# -----Varriables----------------------------------------
mute_status=$(pamixer --get-mute)

if [ $mute_status == true ]
then
    mute="箚빢 Unmute"
else
    mute="箚씇 Mute"
fi
controls="箚뮄 More Controls"

options="$mute\n$controls"

# -----Dmenu---------------------------------------------
select=$(echo -e $options | dmenu -c -p "Audio Options:" -nb $color0 -nf $color6 -sb $color3 -sf $color7 -fn Pangolin -l 5)

# -----Execute-------------------------------------------
case $select in
    $mute)
        pamixer -t
    ;;
    $controls)
        hyprctl dispatch workspace special:magic > /dev/null &&
        pavucontrol
    ;;
esac
