#!/usr/bin/env bash

. $HOME/.cache/wal/colors.sh

if [[ ! -d "$HOME/Pictures/Wallpapers" ]]
then
    folder=$HOME/.config/wallpapers
else
    input=$(echo -e "My Wallpapers\nDefault" | dmenu -c -nb $color0 -nf $color6 -sb $color3 -sf $color7 -fn Pangolin -l 3 -p "Folder:" || exit 0)
    if [[ $input = "My Wallpapers" ]]
    then
        folder=$HOME/Pictures/Wallpapers
    elif [ $input == "Default" ]
    then
        folder=$HOME/.config/wallpapers
    else
#        notify-send "$input" &&
#        notify-send "Cancelled Operation" &&
        exit 0
    fi
fi

wallpaper=$(ls $folder | dmenu -c -nb $color0 -nf $color6 -sb $color3 -sf $color7 -fn Pangolin -l 5 -p "Wallpaper:" || exit 0)
if [ -z $wallpaper ]
then
    exit 0
fi

alpha=$(dmenu -c -nb $color0 -nf $color6 -sb $color3 -sf $color7 -fn Pangolin -l 1 -p "Transparency [0-100] [ENTER = 100]:" <&- || exit 0)
if [ -z $alpha ]
then
    alpha=100
fi

backend=$(echo -e "wal\ncolorz" | dmenu -c -nb $color0 -nf $color6 -sb $color3 -sf $color7 -fn Pangolin -l 3 -p "Backend:" || exit 0)
if [ -z $backend ]
then
    exit 0
fi

lock-bg() {
    wallpaper_cache="$HOME/.cache/blur_wallpaper.png"
    options="-blur 50x50"
    magick $folder/$wallpaper -verbose $options $wallpaper_cache &&
    notify-send -i none "Done"
}

dmenu-make() {
    cd ~/.config/dmenu
    sudo make clean install
}

transition=wipe

wal -i $folder/$wallpaper --cols16 --backend $backend -a $alpha
bash ~/.config/dunst/dunst-build.sh
swww img $folder/$wallpaper --transition-type $transition &&
bash ~/.config/spicetify/Themes/wal/spicetify-wal
lock-bg
